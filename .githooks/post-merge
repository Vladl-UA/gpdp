#!/bin/sh
# После каждого git pull/merge: если приехала правка кода резолвера —
# пересобрать снапшот. Претензия Влада 07-13: снапшот на диске не знает
# о правках КОДА сам по себе, обновляется только как побочный эффект
# структурных действий конфигуратора.
#
# 2026-07-20, переделано. Раньше сигналом был отслеживаемый git-файл
# SNAPSHOT_REBUILD_REQUIRED, который коммитил автор системной правки, а
# хук удалял из рабочего каталога. Механизм оказался одноразовым:
# удаление файла хуком не удаляет его из репозитория, и следующий
# `touch` не создаёт для git никакого изменения — коммит уезжает без
# флага, на сервере файл уже удалён локально, хук молча не срабатывает.
# Ровно то тихое расхождение, против которого флаг и заводился. Вскрылось
# при первом же настоящем применении (коммит fe0ad47), спустя неделю
# после введения.
#
# Теперь сигнал спрашивается у git — он это знает и без нашей дисциплины
# (тот же принцип, что в решении 07-14: где есть механический способ,
# опираться на «не забыть проставить» — шаг назад).
PREV=$(git rev-parse --verify --quiet ORIG_HEAD || git rev-parse --verify --quiet 'HEAD@{1}')

NEED=0
if [ -n "$PREV" ] && git diff-tree -r --name-only "$PREV" HEAD |
        grep -qE '^(core|helpers|entities)\.php$'; then
    NEED=1
    REASON="приехала правка core/helpers/entities"
fi

# Ручной запасной выход: файл НЕ отслеживается git (см. .gitignore),
# кладётся руками на сервере, когда пересборка нужна вне общего правила.
if [ -f SNAPSHOT_REBUILD_REQUIRED ]; then
    NEED=1
    REASON="лежит ручной флаг SNAPSHOT_REBUILD_REQUIRED"
fi

if [ "$NEED" = "1" ]; then
    echo "Пересборка снапшота: $REASON"
    if php tools_rebuild_snapshot.php; then
        rm -f SNAPSHOT_REBUILD_REQUIRED
        echo "Снапшот пересобран."
    else
        echo "ПРОВАЛ пересборки — разберитесь и запустите php tools_rebuild_snapshot.php вручную."
        exit 1
    fi
fi
